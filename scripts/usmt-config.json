{
  "$schema": "../schemas/usmt-config-schema.json",
  "usmt": {
    "customPath": "",
    "userScope": "current",
    "users": [],
    "xmlFiles": [
      "MigApp.xml",
      "MigUser.xml",
      "ExcludeCommon.xml"
    ],
    "additionalArgs": [
      "/c",
      "/v:5",
      "/efs:skip"
    ]
  },
  "backup": {
    "outputDir": "$ONEDRIVE\\MigratronBackups",
    "retentionCount": 5,
    "compress": false,
    "encrypt": false,
    "excludePaths": []
  },
  "schedule": {
    "taskName": "MigratronSnapshot",
    "trigger": "Daily",
    "time": "22:00"
  }
}
