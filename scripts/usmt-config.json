{
  "$schema": "../schemas/usmt-config-schema.json",
  "usmt": {
    "customPath": "",
    "userScope": "current",
    "users": [],
    "xmlFiles": ["MigApp.xml", "MigUser.xml", "ExcludeCommon.xml"],
    "additionalArgs": ["/c", "/v:1", "/efs:skip"]
  },
  "backup": {
    "outputDir": "$ONEDRIVE\\MigratronBackups",
    "retentionCount": 5,
    "compress": false,
    "encrypt": false,
    "generateManifest": true,
    "excludePaths": [
      "%OneDrive%",
      "%OneDriveConsumer%",
      "%OneDriveCommercial%",
      "%USERPROFILE%\\Dropbox",
      "%USERPROFILE%\\Google Drive",
      "%USERPROFILE%\\Box",
      "%USERPROFILE%\\Box Sync"
    ],
    "includePaths": [
      "%USERPROFILE%\\AppData\\LocalLow"
    ],
    "waitForSync": true
  },
  "schedule": {
    "taskName": "MigratronSnapshot",
    "trigger": "Daily",
    "time": "22:00"
  }
}
