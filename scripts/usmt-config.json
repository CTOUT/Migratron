{
  "$schema": "../schemas/usmt-config-schema.json",
  "agent": {
    "actionOnUserActivity": "Throttle",
    "autoUpdate": true,
    "idleMinutesThreshold": 15,
    "interceptShutdown": true,
    "showTrayIcon": true
  },
  "backup": {
    "compress": false,
    "encrypt": false,
    "excludePaths": [
      "%OneDrive%",
      "%OneDriveConsumer%",
      "%OneDriveCommercial%",
      "%USERPROFILE%\\Dropbox",
      "%LOCALAPPDATA%\\Google\\DriveFS",
      "%LOCALAPPDATA%\\Box",
      "%USERPROFILE%\\Box",
      "%USERPROFILE%\\Box Sync",
      "%windir%\\ServiceProfiles"
    ],
    "generateManifest": true,
    "gfsRetention": {
      "dailies": 7,
      "monthlies": 12,
      "weeklies": 4
    },
    "includePaths": ["%USERPROFILE%\\AppData\\LocalLow"],
    "outputDir": "$ONEDRIVE\\MigratronBackups",
    "retentionCount": 5,
    "retentionMode": "simple",
    "waitForSync": true
  },
  "schedule": {
    "taskName": "MigratronSnapshot",
    "time": "22:00",
    "trigger": "Daily"
  },
  "usmt": {
    "additionalArgs": ["/c", "/v:1", "/efs:skip"],
    "customPath": "",
    "users": [],
    "userScope": "current",
    "xmlFiles": ["MigApp.xml", "MigUser.xml", "ExcludeCommon.xml"]
  }
}
